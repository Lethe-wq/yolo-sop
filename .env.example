# 服务地址
SOP_HOST=0.0.0.0
SOP_PORT=10000

# 推理设备: auto / cpu / cuda:0
SOP_DEVICE=auto

# 兼容旧配置保留；模型和训练目录不再依赖该值
SOP_YOLO_DIR=

# 模型与基础权重路径，支持绝对路径或相对当前项目根目录的相对路径
SOP_MODEL_WEIGHTS=yolov8s.pt
SOP_BASE_WEIGHTS=yolov8s.pt

# 推理配置
SOP_DEFAULT_CONFIDENCE=0.25
SOP_MAX_IMAGE_SIZE_MB=10

# 训练数据 ZIP 限制
SOP_MAX_DATASET_ZIP_SIZE_MB=4096
SOP_MAX_DATASET_EXTRACT_SIZE_GB=20
SOP_MAX_DATASET_FILE_COUNT=100000
